# --- Site ---------------------------------------------------------------
# Canonical origin used for metadata, sitemap, hreflang. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://dxbpropertygate.com

# --- Analytics (§3) — optional, scripts load only when set ---------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Lead storage (§9) — first configured backend wins --------------------
# (a) Proxy to an existing FastAPI/MySQL service:
LEAD_ENDPOINT_URL=
LEAD_ENDPOINT_TOKEN=
# (b) Supabase/Postgres (`leads` table via PostgREST):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Lead notifications (§9) ----------------------------------------------
# Email via Resend:
RESEND_API_KEY=
LEAD_EMAIL_TO=sales@example.com
LEAD_EMAIL_FROM=leads@dxbpropertygate.com
# WhatsApp Business Cloud API (template message to the sales number):
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_SALES_NUMBER=
WHATSAPP_TEMPLATE_NAME=new_lead
